<UserControl x:Class="anbar.User_Controls.PaintPrice"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1300" Loaded="UserControl_Loaded">
    <Grid>
        <Border x:Name="panel" Visibility="Collapsed" Width="250" Height="100" Margin="65,0,0,340" CornerRadius="5" Panel.ZIndex="1" BorderThickness="1" BorderBrush="Black">
            <Border.Background>
                <SolidColorBrush Color="#FFC7CAFB"/>
            </Border.Background>
            <Grid Width="245" Height="95">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Button x:Name="b10_2" Content="10.2" Style="{StaticResource gb}" Grid.Column="0" Grid.Row="0" Click="b10_2_Click"/>
                <Button x:Name="b11_8" Content="11.8" Style="{StaticResource gb}" Grid.Column="1" Grid.Row="0" Click="b11_8_Click"/>
                <Button x:Name="b12" Content="12" Style="{StaticResource gb}" Grid.Column="2" Grid.Row="0" Click="b12_Click"/>
                <Button x:Name="b12_5" Content="12.5" Style="{StaticResource gb}" Grid.Column="3" Grid.Row="0" Click="b12_5_Click"/>
                <Button x:Name="b13_2" Content="13.2" Style="{StaticResource gb}" Grid.Column="4" Grid.Row="0" Click="b13_2_Click"/>
                <Button x:Name="b14" Content="14" Style="{StaticResource gb}" Grid.Column="5" Grid.Row="0" Click="b14_Click"/>
                <Button x:Name="b14_5" Content="14.5" Style="{StaticResource gb}" Grid.Column="0" Grid.Row="1" Click="b14_5_Click"/>
                <Button x:Name="b14_8" Content="14.8" Style="{StaticResource gb}" Grid.Column="1" Grid.Row="1" Click="b14_8_Click"/>
                <Button x:Name="b15_8" Content="15.8" Style="{StaticResource gb}" Grid.Column="2" Grid.Row="1" Click="b15_8_Click"/>
                <Button x:Name="b16" Content="16" Style="{StaticResource gb}" Grid.Column="3" Grid.Row="1" Click="b16_Click"/>
                <Button x:Name="b17_2" Content="17.2" Style="{StaticResource gb}" Grid.Column="4" Grid.Row="1" Click="b17_2_Click"/>
                <Button x:Name="b17_8" Content="17.8" Style="{StaticResource gb}" Grid.Column="5" Grid.Row="1" Click="b17_8_Click"/>
                <Button x:Name="b18" Content="18" Style="{StaticResource gb}" Grid.Column="0" Grid.Row="2" Click="b18_Click"/>
                <Button x:Name="b20" Content="20" Style="{StaticResource gb}" Grid.Column="1" Grid.Row="2" Click="b20_Click"/>
                <Button x:Name="b21_8" Content="21.8" Style="{StaticResource gb}" Grid.Column="2" Grid.Row="2" Click="b21_8_Click"/>
                <Button x:Name="b22" Content="22" Style="{StaticResource gb}" Grid.Column="3" Grid.Row="2" Click="b22_Click"/>
                <Button x:Name="b23_5" Content="23.5" Style="{StaticResource gb}" Grid.Column="4" Grid.Row="2" Click="b23_5_Click"/>
                <Button x:Name="b24" Content="24" Style="{StaticResource gb}" Grid.Column="5" Grid.Row="2" Click="b24_Click"/>
                <Button x:Name="b27" Content="27" Style="{StaticResource gb}" Grid.Column="0" Grid.Row="3" Click="b27_Click"/>
                <Button x:Name="b28" Content="28" Style="{StaticResource gb}" Grid.Column="1" Grid.Row="3" Click="b28_Click"/>
                <Button x:Name="b30" Content="30" Style="{StaticResource gb}" Grid.Column="2" Grid.Row="3" Click="b30_Click"/>
                <Button x:Name="b32" Content="32" Style="{StaticResource gb}" Grid.Column="3" Grid.Row="3" Click="b32_Click"/>
            </Grid>
        </Border>
        <Border Width="1050" Height="100" CornerRadius="10" Margin="0,0,0,500">
            <Border.Background>
                <SolidColorBrush Color="Blue" Opacity="0.2"/>
            </Border.Background>
            <Grid>
                <Label Style="{StaticResource lbl}" Content="اندازه برش میل :" Height="50" VerticalContentAlignment="Center"/>
                <Label Style="{StaticResource lbl}" Content="تعداد :" Height="50" VerticalContentAlignment="Center" Margin="0,0,250,0"/>
                <Label Style="{StaticResource lbl}" Content="قطر میله :" Height="50" VerticalContentAlignment="Center" Margin="0,0,430,0"/>
                <Label Style="{StaticResource lbl}" Content="قیمت رنگ (Kg) :" Height="50" VerticalContentAlignment="Center" Margin="0,0,650,0"/>
                <Border Style="{StaticResource brd}" Margin="700,0,0,0" Width="90"/>
                <Border Style="{StaticResource brd}" Margin="345,0,0,0" Width="90"/>
                <Border Style="{StaticResource brd}" Margin="0,0,665,0" Width="150"/>
                <Border x:Name="border" Style="{StaticResource brd}" Margin="0,0,65,0" Width="90"/>
                <Button x:Name="drop" Width="30" Height="30" Margin="0,0,180,0" BorderThickness="0" Cursor="Hand" Click="drop_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border BorderThickness="0" CornerRadius="5">
                                            <Border.Background>
                                                <ImageBrush ImageSource="/Source/Pic/drop.png" Stretch="Fill"/>
                                            </Border.Background>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBox x:Name="size" Style="{StaticResource tbf}" Width="70" Margin="700,0,0,0" HorizontalContentAlignment="Center" MaxLength="6" PreviewKeyDown="size_PreviewKeyDown"/>
                <TextBox x:Name="number" Style="{StaticResource tbf}" Width="70" HorizontalContentAlignment="Center" MaxLength="4" Margin="345,0,0,0" PreviewKeyDown="number_PreviewKeyDown"/>
                <TextBox x:Name="diameter" Style="{StaticResource tbf}" Width="70" HorizontalContentAlignment="Center" MaxLength="4" Margin="0,0,65,0" TextChanged="diameter_TextChanged" PreviewKeyDown="diameter_PreviewKeyDown"/>
                <TextBox x:Name="price" Style="{StaticResource tbf}" Width="130" Margin="0,0,665,0" HorizontalContentAlignment="Center" MaxLength="10" TextChanged="price_TextChanged" PreviewKeyDown="price_PreviewKeyDown"/>
                <TextBox x:Name="formattedText" FontSize="14" FontWeight="Normal" Style="{StaticResource tbf}" Height="25" IsReadOnly="True" Width="130" Margin="0,75,665,0" HorizontalContentAlignment="Center"/>
                <Button x:Name="add" Click="add_Click" Margin="0,0,920,35">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Width" Value="30"/>
                            <Setter Property="Height" Value="30"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Image Source="/Source/Pic/add.png"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="del" Click="del_Click" Margin="0,35,920,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Width" Value="30"/>
                            <Setter Property="Height" Value="30"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Image Source="/Source/Pic/del.png"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </Grid>
        </Border>
        <Border Width="1050" Height="500" CornerRadius="10" BorderThickness="0" Margin="0,120,0,0">
            <Border.Background>
                <SolidColorBrush Color="Blue" Opacity="0.2"/>
            </Border.Background>
            <Grid>
                <Label Style="{StaticResource lbl}" Content="قیمت نهایی :" Margin="0,430,575,0" FontSize="26"/>
                <ListView FontFamily="pack://application:,,,/Fonts/#Vazir" FontWeight="Bold" x:Name="data" ItemsSource="{Binding paintFee}" Width="1000" Height="400" Margin="0,0,0,50" FontSize="24" FlowDirection="RightToLeft">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header="تعداد" Width="200" DisplayMemberBinding="{Binding Number}"/>
                            <GridViewColumn Header="وزن حجمی" Width="200" DisplayMemberBinding="{Binding Weight}"/>
                            <GridViewColumn Header="اندازه برش" Width="200" DisplayMemberBinding="{Binding Size}"/>
                            <GridViewColumn Header="وزن (Kg)" Width="200" DisplayMemberBinding="{Binding Price}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
                <Button x:Name="show" Click="show_Click" Tag="/Source/Pic/cal.png" Content="محاسبه قیمت" Style="{StaticResource ubtn}" Margin="840,425,0,0"/>
            </Grid>
        </Border>
        <Border Width="300" Height="60" Margin="0,530,700,0" CornerRadius="0,0,10,10">
            <Border.Background>
                <SolidColorBrush Color="Blue" Opacity="0.2"/>
            </Border.Background>
            <TextBox x:Name="result" Style="{StaticResource tbf}" Width="290" HorizontalContentAlignment="Center" IsReadOnly="True"/>
        </Border>
    </Grid>
</UserControl>
