<UserControl x:Class="anbar.User_Controls.UCConfirmSellForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1300" Background="White" Loaded="UserControl_Loaded" Focusable="True" PreviewKeyDown="UserControl_PreviewKeyDown">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style x:Key="CenterTextBlockStyle" TargetType="TextBlock">

                <Setter Property="TextAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="CenterTextBlockStyle1" TargetType="TextBlock">
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Language" Value="fa-IR"/>
                <Setter Property="FontSize" Value="40"/>
                <Setter Property="FlowDirection" Value="RightToLeft"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer>
        <Grid>
            <Button x:Name="back" Click="back_Click" Width="35" Height="35" Margin="0,0,1200,1600">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Image Source="/Source/Pic/back.png"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Viewbox Width="1200" Height="1700">
                <Grid x:Name="main" Width="2480" Height="3508">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="480"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Label Style="{StaticResource lbl}" Content="فاکتور تایید شده" HorizontalAlignment="Center" FontSize="60" Margin="0,50,0,0"/>
                    <Border Style="{StaticResource fb}" Width="2400" Height="300" VerticalAlignment="Top" BorderThickness="4" Margin="0,170,0,0"/>
                    <Label Style="{StaticResource lbl}" Content="شماره فاکتور :" FontSize="45" Margin="0,190,50,0"/>
                    <Label Style="{StaticResource lbl}" Content="فروشنده :" FontSize="45" Margin="0,280,50,0"/>
                    <Label Style="{StaticResource lbl}" Content="خریدار :" FontSize="45" Margin="0,375,50,0"/>
                    <Label Style="{StaticResource lbl}" Content="آدرس خریدار :" FontSize="45" Margin="0,370,1000,0"/>
                    <Label Style="{StaticResource lbl}" Content="تاریخ :" FontSize="45" Margin="0,190,1000,0"/>
                    <Label Style="{StaticResource lbl}" Content="/" FontSize="45" Margin="0,195,1200,0"/>
                    <Label Style="{StaticResource lbl}" Content="/" FontSize="45" Margin="0,195,1295,0"/>
                    <Label Style="{StaticResource lbl}" Content="تلفن خریدار :" FontSize="45" Margin="0,280,1000,0"/>
                    <Label Style="{StaticResource lbl}" Content="-" FontSize="45" Margin="0,280,1475,0"/>
                    <TextBox x:Name="txtinvoiceId" Style="{StaticResource tbf}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Width="150" Height="85" VerticalAlignment="Top" FontSize="55" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="1690,188,0,0" IsReadOnly="True" MaxLength="5"/>
                    <TextBox IsReadOnly="True" x:Name="txtDay" Style="{StaticResource tbf}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="50" VerticalAlignment="Top" Width="65" Height="85" Margin="140,188,0,0" MaxLength="2" HorizontalContentAlignment="Center"/>
                    <TextBox IsReadOnly="True" x:Name="txtMonth" Style="{StaticResource tbf}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="50" VerticalAlignment="Top" Width="65" Height="85" Margin="0,188,50,0" MaxLength="2" HorizontalContentAlignment="Center"/>
                    <TextBox IsReadOnly="True" x:Name="txtYear" Style="{StaticResource tbf}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="50" VerticalAlignment="Top" Width="120" Height="85" Margin="0,188,295,0" MaxLength="4" HorizontalContentAlignment="Center"/>
                    <TextBox IsReadOnly="True" x:Name="txtNameS" Style="{StaticResource tbf}" FontSize="45" VerticalAlignment="Top" Width="630" Height="85" Margin="1350,278,0,0"/>
                    <TextBox IsReadOnly="True" x:Name="txtNameB" Style="{StaticResource tbf}" FontSize="45" VerticalAlignment="Top" Width="630" Height="85" Margin="1425,369,0,0"/>
                    <TextBox IsReadOnly="True" x:Name="txtPhone" Style="{StaticResource tbf}" FontSize="45" VerticalAlignment="Top" Width="210" Height="85" Margin="0,278,255,0" MaxLength="8"/>
                    <TextBox IsReadOnly="True" x:Name="txtPhoneCode" Style="{StaticResource tbf}" FontSize="45" VerticalAlignment="Top" Width="120" Height="85" Margin="0,278,650,0" MaxLength="4"/>
                    <TextBox IsReadOnly="True" x:Name="txtAddress" Style="{StaticResource tbf}" FontSize="35" VerticalAlignment="Top" Width="1030" Height="85" Margin="170,368,1280,0"/>
                    <Grid Width="2400" MinHeight="500" Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- برای ردیف دیتاگرید به صورت خودکار قرار دادیم -->
                            <RowDefinition Height="Auto"/>
                            <!-- برای ردیف Border کوچکتر به صورت خودکار -->
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <!-- عرض یکسان برای هر دو ستون -->
                        </Grid.ColumnDefinitions>

                        <!-- Border بزرگتر که دیتاگرید در آن قرار می‌گیرد -->
                        <Border CornerRadius="5,5,10,0" Style="{StaticResource fb}" Width="2400" MinHeight="142" Height="Auto" BorderThickness="0,0,4,0" Margin="0,0,0,0" Grid.Row="0" VerticalAlignment="Stretch">
                            <DataGrid x:Name="myDataGrid" Background="White" Height="Auto" Width="2400" CanUserResizeRows="False" RowHeaderWidth="0" HorizontalScrollBarVisibility="Disabled" CanUserAddRows="False" CanUserResizeColumns="False" CanUserReorderColumns="False" FontSize="50" AutoGenerateColumns="False" FlowDirection="RightToLeft" FontFamily="pack://application:,,,/Fonts/#B Nazanin"  BorderThickness="0,0,4,3" BorderBrush="Black" HorizontalGridLinesBrush="Black" VerticalGridLinesBrush="Black" AlternatingRowBackground="Transparent" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="کد کالا" Width="350" CanUserResize="False" CanUserSort="False" Binding="{Binding ProductCode}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}">
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="FontSize" Value="45"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="BorderThickness" Value="4,4,1.5,4"/>
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="FontSize" Value="45"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="نام کالا" Width="990" CanUserResize="False" CanUserSort="False" Binding="{Binding ProductName}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle1}">
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="BorderThickness" Value="4,4,1.5,4"/>
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="FontSize" Value="45"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="تعداد" Width="160" CanUserResize="False" CanUserSort="False" Binding="{Binding InvoiceItemNumber}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}">
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="BorderThickness" Value="4,4,1,4"/>
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="FontSize" Value="45"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="قیمت واحد" Width="450" CanUserResize="False" CanUserSort="False" Binding="{Binding InvoiceItemPrice}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}">
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="BorderThickness" Value="4,4,1,4"/>
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="FontSize" Value="45"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="جمع" Width="450" CanUserResize="False" CanUserSort="False" Binding="{Binding InvoiceFinalPrice}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CenterTextBlockStyle}">
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                        <DataGridTextColumn.HeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                                <Setter Property="BorderThickness" Value="4,4,0,4"/>
                                                <Setter Property="BorderBrush" Value="Black"/>
                                                <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="FontSize" Value="45"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </Style>
                                        </DataGridTextColumn.HeaderStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#B Nazanin"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                        <Setter Property="BorderBrush" Value="Black"/>
                                        <Setter Property="Focusable" Value="False"/>

                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="4,1,0,0"/>
                                        <Setter Property="BorderBrush" Value="Black"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Height" Value="60"/>
                                        <Setter Property="Focusable" Value="False"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </DataGrid.CellStyle>
                            </DataGrid>
                        </Border>

                        <!-- Border کوچکتر -->
                        <Border CornerRadius="0,0,10,10" Style="{StaticResource fb}" Width="452" Height="222" BorderThickness="4,0,5,4" VerticalAlignment="Top" Margin="0,0,0,0" Grid.Row="1" HorizontalAlignment="Left">
                            <Grid>
                                <Border Style="{StaticResource fb}" Height="74" VerticalAlignment="Top" BorderThickness="0,0,0,0" CornerRadius="0"/>
                                <Border Style="{StaticResource fb}" Height="74" VerticalAlignment="Center" BorderThickness="0,4,0,4" CornerRadius="0"/>
                                <Border Style="{StaticResource fb}" Height="74" VerticalAlignment="Bottom"  CornerRadius="0" BorderThickness="0"/>
                            </Grid>
                        </Border>
                        <Label Grid.Row="1" Style="{StaticResource lbl}" HorizontalContentAlignment="Right" Height="70" Width="280" FontSize="45" Content="قیمت نهایی" Margin="0,0,1170,2285"/>
                        <Label Grid.Row="1" Style="{StaticResource lbl}" Height="70" HorizontalContentAlignment="Right" Width="280" FontSize="45" Content="تخفیف" Margin="0,0,1170,2140"/>
                        <Label Grid.Row="1" Style="{StaticResource lbl}" Height="70" Width="360" HorizontalContentAlignment="Right" FontSize="45" Content="مبلغ قابل پرداخت" Margin="0,0,1090,2010"/>
                        <TextBox x:Name="txtfinalPrice" Grid.Row="1" Style="{StaticResource tbf}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Top" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Height="70" Width="450" FontSize="55" IsReadOnly="True" HorizontalAlignment="Left"/>
                        <TextBox x:Name="txtdiscount" Grid.Row="1" Style="{StaticResource tbf}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Height="70" Width="450" FontSize="55" Margin="0,0,0,2145" HorizontalAlignment="Left"/>
                        <TextBox x:Name="txtfinalPay" Grid.Row="1" Style="{StaticResource tbf}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Left" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Height="70" Width="450" FontSize="55" Margin="0,0,0,1995" IsReadOnly="True"/>

                        <TextBox IsReadOnly="True" x:Name="txtdetail" Style="{StaticResource tbf}" Grid.Row="1" Width="2280" Height="70" Margin="100,0,0,1750" FontSize="40"/>
                        <TextBox IsReadOnly="True" x:Name="txtdetail2" Style="{StaticResource tbf}" Grid.Row="1" Width="2280" Height="280" Margin="100,0,0,1380" FontSize="40"/>
                    </Grid>
                </Grid>
            </Viewbox>
        </Grid>
    </ScrollViewer>
</UserControl>
