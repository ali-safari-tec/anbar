<UserControl x:Class="anbar.User_Controls.AddOrEditPerson"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" KeyDown="UserControl_KeyDown" Loaded="UserControl_Loaded" Background="White">
    <Grid Width="1100" Height="500">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Image x:Name="a1" Source="/Source/Pic/About.png" Width="20" Stretch="Uniform" Grid.Column="2" Margin="290,10,0,0"/>
        <Image x:Name="a2" Source="/Source/Pic/About.png" Width="20" Stretch="Uniform" Grid.Column="2" Margin="0,10,150,0"/>

        <GroupBox Header="{Binding TitlePerson, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AddOrEditPerson}}}" Grid.Column="0" HorizontalAlignment="Right" FontSize="20" FontWeight="Bold" FontFamily="pack://application:,,,/Fonts/#Vazir" Width="1080" Height="430" VerticalAlignment="Top" Margin="0,10,10,0" BorderThickness="2" Grid.ColumnSpan="3" Grid.RowSpan="3" FlowDirection="RightToLeft"/>
        
        <Label Style="{StaticResource lbl}" Content="کد :" Grid.Column="2" Margin="0,70,50,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Margin="400,40,0,25" Grid.ColumnSpan="2" Width="150"/>
        <TextBox x:Name="IdPerson" Style="{StaticResource tbf}" Grid.Column="1" Margin="400,40,0,25" Grid.ColumnSpan="2" Width="130" TextChanged="IdPerson_TextChanged" PreviewKeyDown="IdPerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="کد انتخابی برای شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="نام :" Grid.Column="2" Margin="0,70,270,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Margin="0,40,195,25" Grid.ColumnSpan="2" Width="300"/>
        <TextBox x:Name="namePerson" Style="{StaticResource tbf}" Grid.Column="1" Margin="0,40,195,25" Grid.ColumnSpan="2" Width="280" TextChanged="namePerson_TextChanged" PreviewKeyDown="namePerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="نام و نام خانوادگی شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="نوع شخص :" Grid.Column="1" Margin="0,70,265,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Margin="0,40,300,25" Grid.ColumnSpan="2" Width="300"/>
        <TextBox x:Name="modelPerson" Style="{StaticResource tbf}" Grid.Column="0" Margin="0,40,300,25" Grid.ColumnSpan="2" Width="280" PreviewKeyDown="modelPerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="نوع شخص (برای مثال : خوش حساب،بدحساب،... و یا چکی،نقدی،...)" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="شهر :" Grid.Column="2" Margin="0,130,54,0" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Margin="220,0,0,35" Grid.ColumnSpan="2" Width="300" Grid.RowSpan="2"/>
        <TextBox x:Name="cityPerson" Style="{StaticResource tbf}" Grid.Column="1" Margin="220,0,0,35" Grid.ColumnSpan="2" Width="280" Grid.RowSpan="2" PreviewKeyDown="cityPerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="شهر شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="استان :" Grid.Column="1" Margin="0,130,155,0" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Margin="0,0,5,35" Grid.ColumnSpan="2" Width="300" Grid.RowSpan="2"/>
        <TextBox x:Name="provincePerson" Style="{StaticResource tbf}" Grid.Column="0" Margin="0,0,5,35" Grid.ColumnSpan="2" Width="280" Grid.RowSpan="2" PreviewKeyDown="provincePerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="استان شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="تلفن :" Grid.Column="2" Margin="0,185,50,0" Grid.Row="0" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Margin="220,80,0,0" Grid.ColumnSpan="2" Width="300" Grid.Row="0" Grid.RowSpan="2"/>
        <TextBox x:Name="phonePerson" Style="{StaticResource tbf}" Grid.Column="1" Margin="220,85,0,0" Grid.ColumnSpan="2" Width="280" Grid.Row="0" Grid.RowSpan="2" MaxLength="8" PreviewKeyDown="phonePerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="شماره تلفن ثابت شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Border Style="{StaticResource brd}" Grid.Column="1" Margin="0,80,160,0" Grid.ColumnSpan="2" Width="70" Grid.Row="0" Grid.RowSpan="2"/>
        <TextBox x:Name="phoneCodePerson" Style="{StaticResource tbf}" Grid.Column="1" Margin="0,80,160,0" Grid.ColumnSpan="2" Width="50" Grid.Row="0" Grid.RowSpan="2" MaxLength="4" PreviewKeyDown="phoneCodePerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="کد منطقه تلفن ثابت شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="موبایل :" Grid.Column="1" Margin="0,185,150,0" Grid.Row="0" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Margin="0,80,5,0" Grid.ColumnSpan="2" Width="300" Grid.Row="0" Grid.RowSpan="2"/>
        <TextBox x:Name="mobilePerson" Style="{StaticResource tbf}" Grid.Column="0" Margin="0,80,5,0" Grid.ColumnSpan="2" Width="280" Grid.Row="0" Grid.RowSpan="2" MaxLength="11" PreviewKeyDown="mobilePerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="شماره موبایل شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="آدرس :" Grid.Column="2" Margin="0,245,50,0" Grid.Row="0" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Margin="0,200,50,0" Grid.ColumnSpan="3" Width="925" Grid.Row="0" Grid.RowSpan="2"/>
        <TextBox x:Name="addressPerson" Style="{StaticResource tbf}" Grid.Column="0" Margin="0,200,50,0" Grid.ColumnSpan="3" Width="905" Grid.Row="0" Grid.RowSpan="2" PreviewKeyDown="addressPerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="آدرس شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Label Style="{StaticResource lbl}" Content="توضیحات :" Grid.Column="2" Margin="0,140,50,0" Grid.Row="1" Grid.RowSpan="2"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Margin="0,0,75,15" Grid.ColumnSpan="3" Width="900" Grid.Row="1" Grid.RowSpan="2"/>
        <TextBox x:Name="infoPerson" Style="{StaticResource tbf}" Grid.Column="0" Margin="0,0,70,15" Grid.ColumnSpan="3" Width="880" Grid.Row="1" Grid.RowSpan="2" PreviewKeyDown="infoPerson_KeyDown">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="توضیحات تکمیلی شخص" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
        <Button x:Name="save" Click="Save_Click" Style="{StaticResource ubtn}" Content="  ذخیره اطلاعات" Tag="/Source/pic/save.png" Grid.Column="2" Grid.Row="2" Margin="100,0,0,30">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="ثبت اطلاعات" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
            </Button.ToolTip>
        </Button>
        <Button x:Name="cancel" Click="Cancel_Click" Style="{StaticResource ubtn}" Content="      انصراف" Tag="/Source/pic/cancel.png" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Margin="130,0,0,30">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="انصراف" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
            </Button.ToolTip>
        </Button>
    </Grid>
</UserControl>
