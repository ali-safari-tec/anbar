<UserControl x:Class="anbar.User_Controls.USPerson"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1300" Loaded="UserControl_Loaded" PreviewKeyDown="UserControl_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <GroupBox Header="معرفی اشخاص" Grid.Column="0" HorizontalAlignment="Right" FontSize="24" FontWeight="Bold" FontFamily="pack://application:,,,/Fonts/#Vazir" Width="1280" Height="700" VerticalAlignment="Top" Margin="0,10,10,0" BorderThickness="2" Grid.ColumnSpan="3" Grid.RowSpan="3" FlowDirection="RightToLeft"/>

        <DataGrid x:Name="dgInvoice" FlowDirection="RightToLeft" Grid.ColumnSpan="2" Grid.RowSpan="3" Grid.Column="1" HorizontalAlignment="Right" Width="500" Height="560" Margin="0,0,20,15" BorderThickness="0" CanUserResizeRows="False" RowHeaderWidth="0" GridLinesVisibility="None" HorizontalScrollBarVisibility="Disabled" CanUserAddRows="False" CanUserResizeColumns="False" CanUserReorderColumns="False" AutoGenerateColumns="False" SelectionChanged="dgInvoice_SelectionChanged" PreviewKeyDown="dgInvoice_KeyDown" IsReadOnly="True" MouseDown="dgInvoice_MouseDown">
            <DataGrid.Background>
                <SolidColorBrush Color="Blue" Opacity="0.2"/>
            </DataGrid.Background>
            <DataGrid.Columns>
                <DataGridTextColumn Header="کد اشخاص" Binding="{Binding PersonIdByUser}" Width="150">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                            <Setter Property="FontSize" Value="20"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="نام اشخاص" Binding="{Binding PersonName}" Width="350">
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                            <Setter Property="FontSize" Value="20"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Margin" Value="5,5,5,0"/>
                    <Setter Property="Background" Value="LightBlue"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="FontSize" Value="20"/>
                    <Setter Property="FontFamily" Value="pack://application:,,,/Fonts/#Vazir"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridRow">
                                <Border CornerRadius="10" Background="{TemplateBinding Background}">
                                    <DataGridCellsPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Margin" Value="10,0,0,0"/>
                </Style>
            </DataGrid.CellStyle>
        </DataGrid>

        <Grid Grid.RowSpan="3" Grid.ColumnSpan="2" Width="800" Height="650">
            <!-- label fot titles -->
            <Label Style="{StaticResource lbl}" Content="جستجو :" FontSize="25" Width="300" Height="50" HorizontalContentAlignment="Right" Margin="380,0,0,550"/>
            <Label Style="{StaticResource lbl}" Content="نوع شخص :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,0,0,430"/>
            <Label Style="{StaticResource lbl}" Content="شهر :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,0,0,310"/>
            <Label Style="{StaticResource lbl}" Content="استان :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,0,0,190"/>
            <Label Style="{StaticResource lbl}" Content="شماره تلفن :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,0,0,70"/>
            <Label Style="{StaticResource lbl}" Content="شماره موبایل :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,50,0,0"/>
            <Label Style="{StaticResource lbl}" Content="آدرس :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,170,0,0"/>
            <Label Style="{StaticResource lbl}" Content="توضیحات :" FontSize="25" Width="210" Height="50" HorizontalContentAlignment="Right" Margin="480,390,0,0"/>
            <!-- border for textbox -->
            <Border Style="{StaticResource brd}" Width="300" Height="50" Margin="0,0,230,550"/>
            <Border Style="{StaticResource brd}" Width="500" Height="50" Margin="0,0,230,430"/>
            <Border Style="{StaticResource brd}" Width="500" Height="50" Margin="0,0,230,310"/>
            <Border Style="{StaticResource brd}" Width="500" Height="50" Margin="0,0,230,190"/>
            <Border Style="{StaticResource brd}" Width="155" Height="50" Margin="115,0,0,70"/>
            <Border Style="{StaticResource brd}" Width="65" Height="50" Margin="0,0,115,70"/>
            <Border Style="{StaticResource brd}" Width="190" Height="50" Margin="80,50,0,0"/>
            <Border Style="{StaticResource brd}" Width="500" Height="100" Margin="0,220,230,0"/>
            <Border Style="{StaticResource brd}" Width="500" Height="100" Margin="0,440,230,0"/>
            <!-- textbox readonly for show detail of invoice -->
            <TextBox x:Name="search" Style="{StaticResource tbf}" Width="280" Height="50" Margin="0,0,230,550" FontSize="22" FontFamily="pack://application:,,,/Fonts/#Vazir" TextChanged="search_TextChanged"/>
            <TextBox x:Name="type" Style="{StaticResource tbf}" Width="480" Height="50" Margin="0,0,230,430" IsReadOnly="True" FontSize="22" FontFamily="pack://application:,,,/Fonts/#Vazir"/>
            <TextBox x:Name="city" Style="{StaticResource tbf}" Width="480" Height="50" Margin="0,0,230,310" IsReadOnly="True" FontSize="22" FontFamily="pack://application:,,,/Fonts/#Vazir"/>
            <TextBox x:Name="province" Style="{StaticResource tbf}" Width="480" Height="50" Margin="0,0,230,190" IsReadOnly="True" FontSize="22" FontFamily="pack://application:,,,/Fonts/#Vazir"/>
            <TextBox x:Name="phone" Style="{StaticResource tbf}" Width="135" HorizontalContentAlignment="Center" Height="50" Margin="115,0,0,70" IsReadOnly="True" FontSize="30" FontFamily="pack://application:,,,/Fonts/#B Nazanin"/>
            <TextBox x:Name="phoneCode" Style="{StaticResource tbf}" Width="45" HorizontalContentAlignment="Center" Height="50" Margin="0,0,115,70" IsReadOnly="True" FontSize="30" FontFamily="pack://application:,,,/Fonts/#B Nazanin"/>
            <TextBox x:Name="mobile" Style="{StaticResource tbf}" Width="170" Height="50" Margin="80,50,0,0" IsReadOnly="True" FontSize="30" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="address" Style="{StaticResource tbf}" Width="480" Height="90" Margin="0,220,230,0" IsReadOnly="True" FontSize="20" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" FontFamily="pack://application:,,,/Fonts/#Vazir"/>
            <TextBox x:Name="detail" Style="{StaticResource tbf}" Width="480" Height="90" Margin="0,440,230,0" IsReadOnly="True" FontSize="20" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" FontFamily="pack://application:,,,/Fonts/#Vazir"/>
        </Grid>

        <Button x:Name="add" Click="add_Click" Tag="/Source/pic/addform.png" Style="{StaticResource ubtn}" Content="   افزودن شخص " Grid.Column="2" Grid.Row="2" Margin="230,160,0,0">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="افزودن شخص جدید" Placement="Top" VerticalOffset="-5" HorizontalOffset="0"/>
            </Button.ToolTip>
        </Button>
        <Button x:Name="edit" Click="edit_Click"  Tag="/Source/pic/edit.png" Style="{StaticResource ubtn}" Content="    ویرایش شخص" Grid.Column="2" Grid.Row="2" Margin="0,160,100,0">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="ویرایش مشخصات فرد مورد نظر" Placement="Top" VerticalOffset="-5" HorizontalOffset="0"/>
            </Button.ToolTip>
        </Button>
        <Button x:Name="delete" Click="delete_Click" Tag="/Source/pic/delete.png" Style="{StaticResource ubtn}" Content="     حذف شخص" Grid.Column="1" Grid.Row="2" Margin="3,160,0,0" Grid.ColumnSpan="2">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="حذف شخص مورد نظر" Placement="Top" VerticalOffset="-5" HorizontalOffset="0"/>
            </Button.ToolTip>
        </Button>
        <Grid x:Name="show" Grid.ColumnSpan="3" Width="1100" Grid.RowSpan="3" Height="500"/>
    </Grid>
</UserControl>
