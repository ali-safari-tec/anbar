<UserControl x:Class="anbar.User_Controls.AddOrEditProduct"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" KeyDown="UserControl_KeyDown" Loaded="UserControl_Loaded">
    <Grid Width="1100" Height="500">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Image x:Name="a1" Source="/Source/Pic/About.png" Width="20" Stretch="Uniform" Grid.Column="1" Margin="90,35,0,0"/>
        <Image x:Name="a2" Source="/Source/Pic/About.png" Width="20" Stretch="Uniform" Grid.Column="2" Margin="290,35,0,0"/>
        <Label x:Name="lbl1" Style="{StaticResource lbl}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="25" Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2" FlowDirection="LeftToRight" Width="300" Height="40" Margin="65,120,0,0"/>
        <Label x:Name="lbl2" Style="{StaticResource lbl}" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="25" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="2" FlowDirection="LeftToRight" Width="300" Height="40" Margin="0,120,130,0"/>

        <GroupBox Header="{Binding TitleProduct, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:AddOrEditProduct}}}" Grid.Column="0" HorizontalAlignment="Right" FontSize="20" FontWeight="Bold" FontFamily="pack://application:,,,/Fonts/#Vazir" Width="1080" Height="430" VerticalAlignment="Top" Margin="0,10,10,0" BorderThickness="2" Grid.ColumnSpan="3" Grid.RowSpan="3" FlowDirection="RightToLeft"/>
        <Button x:Name="save" Click="Save_Click" Style="{StaticResource ubtn}" Content="  ذخیره اطلاعات" Tag="/Source/pic/save.png" Grid.Column="2" Grid.Row="2" Margin="100,0,0,30">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="ثبت اطلاعات" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
            </Button.ToolTip>
        </Button>
        <Button x:Name="cancel" Click="Cancel_Click" Style="{StaticResource ubtn}" Content="      انصراف" Tag="/Source/pic/cancel.png" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Margin="130,0,0,30">
            <Button.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="انصراف" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
            </Button.ToolTip>
        </Button>

        <Label Style="{StaticResource lbl}" Content="کد محصول :" Grid.Column="2" Margin="0,80,50,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="320" Margin="110,30,0,0"/>
        <TextBox x:Name="IdProduct" PreviewKeyDown="IdProduct_KeyDown" Style="{StaticResource tbf}" Grid.Column="1" Grid.ColumnSpan="2" Width="300" Margin="110,30,0,0" TextChanged="IdProduct_TextChanged">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="کد محصول خود را وارد کنید" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>

        <Label Style="{StaticResource lbl}" Content="نام محصول :" Grid.Column="1" Margin="0,80,150,0"/>
        <Border Style="{StaticResource brd}" Margin="0,30,195,0" Grid.ColumnSpan="2" Width="420"/>
        <TextBox x:Name="nameProduct" PreviewKeyDown="nameProduct_KeyDown" Style="{StaticResource tbf}" Margin="0,30,195,0" Grid.ColumnSpan="2" Width="400" TextChanged="nameProduct_TextChanged" Language="fa-IR">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="نام محصول خود را وارد کنید" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>

        <Label Style="{StaticResource lbl}" Content="قیمت محصول :" Grid.Column="2" Grid.Row="1" Margin="0,0,50,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="320" Grid.RowSpan="2" Margin="65,40,0,0"/>
        <TextBox x:Name="priceProduct" PreviewKeyDown="priceProduct_KeyDown" Style="{StaticResource tbf}" Grid.Column="1" Grid.ColumnSpan="2" Width="300" Grid.RowSpan="2" Margin="65,40,0,0" TextChanged="priceProduct_TextChanged">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="قیمت محصول خود را وارد کنید" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>

        <Label Style="{StaticResource lbl}" Content="تعداد محصول :" Grid.Column="1" Grid.Row="1" Margin="0,0,150,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="320" Grid.RowSpan="2" Margin="0,40,130,0"/>
        <TextBox x:Name="countProduct" PreviewKeyDown="countProduct_KeyDown" Style="{StaticResource tbf}" MaxLength="9" Grid.Column="0" Grid.ColumnSpan="2" Width="300" Grid.RowSpan="2" Margin="0,40,130,0" TextChanged="countProduct_TextChanged">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="تعداد محصول خود را وارد کنید" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>

        <Label Style="{StaticResource lbl}" Content="توضیحات محصول :" Grid.Column="2" Grid.Row="1" Margin="0,85,50,0"/>
        <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="3" Width="800" Grid.RowSpan="2" Grid.Row="1" Margin="0,0,105,120"/>
        <TextBox x:Name="infoProduct" PreviewKeyDown="infoProduct_KeyDown" Style="{StaticResource tbf}" Grid.Column="0" Grid.ColumnSpan="3" Width="780" Grid.RowSpan="2" Grid.Row="1" Margin="0,0,105,120">
            <TextBox.ToolTip>
                <ToolTip Style="{StaticResource tip}" Content="توضیحات دلخواه خود برای محصول رو در صورت نیاز وارد کنید" Placement="Top" VerticalOffset="-5"/>
            </TextBox.ToolTip>
        </TextBox>
    </Grid>
</UserControl>
