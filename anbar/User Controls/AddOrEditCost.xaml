<UserControl x:Class="anbar.User_Controls.AddOrEditCost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:anbar.User_Controls"
             mc:Ignorable="d" PreviewKeyDown="UserControl_KeyDown" Loaded="UserControl_Loaded">
    <Border Width="1100" Height="500" Background="White" CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="400" Margin="100,0,0,50"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="50" Height="45" Margin="190,0,0,50"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="50" Height="45" Margin="55,0,0,50"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="80" Height="45" Margin="0,0,110,50"/>
            <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="400" Margin="100,70,0,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="200" Margin="10,70,0,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="136" Grid.RowSpan="2" Margin="363,25,0,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="80" Grid.RowSpan="2" Margin="130,25,0,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="200" Grid.RowSpan="2" Margin="10,25,0,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="1" Grid.ColumnSpan="2" Width="180" Grid.Row="1" Margin="320,0,0,20"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="2" Width="200" Grid.Row="1" Margin="0,0,55,20"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="3" Width="950" Grid.Row="1" Margin="0,100,83.5,0"/>
            <Border Style="{StaticResource brd}" Grid.Column="0" Grid.ColumnSpan="3" Width="950" Grid.Row="1" Grid.RowSpan="2" Margin="0,55,83.5,0"/>

            <Border Style="{StaticResource fb}" CornerRadius="10" Grid.ColumnSpan="3" Grid.RowSpan="3" Width="1080" Height="480"/>

            <Label Style="{StaticResource lbl}" Height="40" Content="فروشنده :" Grid.Column="2" Margin="0,0,30,50"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="عنوان :" Grid.Column="2" Margin="0,70,30,0"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="تلفن :" Grid.Column="2" Grid.RowSpan="2" Margin="0,25,30,0"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="موبایل :" Grid.Column="2" Grid.Row="1" Margin="0,0,30,20"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="آدرس :" Grid.Column="2" Grid.Row="1" Margin="0,100,30,0"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="توضیحات :" Grid.Column="2" Grid.Row="2" Margin="0,0,30,110"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="تاریخ :" Grid.Column="1" Margin="0,0,190,50"/>
            <Label Style="{StaticResource lbl}" FontSize="25" Height="40" Content="/" Grid.Column="1" Margin="0,0,295,55"/>
            <Label Style="{StaticResource lbl}" FontSize="25" Height="40" Content="/" Grid.ColumnSpan="2" Grid.Column="0" Margin="0,0,363,55"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="قیمت :" Grid.Column="1" Margin="0,70,190,0"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="تخفیف :" Grid.Column="1" Grid.RowSpan="2" Margin="0,25,190,0"/>
            <Label Style="{StaticResource lbl}" Height="40" Content="قیمت نهایی :" Grid.Column="1" Grid.Row="1" Margin="0,0,190,20"/>

            <TextBlock x:Name="lblFee" FontSize="25" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Width="250" Height="50" Margin="0,80,85,0" FlowDirection="RightToLeft" FontWeight="Bold"/>
            <TextBlock x:Name="lblDiscount" FontSize="25" FontFamily="pack://application:,,,/Fonts/#B Nazanin" Width="250" Height="50" Grid.RowSpan="2" Margin="0,30,85,0" FlowDirection="RightToLeft" FontWeight="Bold"/>

            <TextBox x:Name="txtSeller" Style="{StaticResource tbf}" Grid.Column="1" Grid.ColumnSpan="2" Width="380" Margin="100,0,0,50" PreviewKeyDown="txtSeller_PreviewKeyDown"/>
            <TextBox x:Name="txtCaption" Style="{StaticResource tbf}" Grid.Column="1" Grid.ColumnSpan="2" Width="380" Margin="100,70,0,0" PreviewKeyDown="txtCaption_PreviewKeyDown"/>
            <TextBox x:Name="txtPhone" Style="{StaticResource tbf}" FontSize="25" Grid.Column="1" Grid.ColumnSpan="2" Width="116" Grid.RowSpan="2" Margin="363,25,0,0" MaxLength="8" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtPhone_PreviewKeyDown"/>
            <TextBox x:Name="txtPhoneCode" Style="{StaticResource tbf}" FontSize="25" Grid.Column="1" Grid.ColumnSpan="2" Width="60" Grid.RowSpan="2" Margin="130,25,0,0" MaxLength="4" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtPhoneCode_PreviewKeyDown"/>
            <TextBox x:Name="txtMobile" Style="{StaticResource tbf}" FontSize="25" Grid.Column="1" Grid.ColumnSpan="2" Width="160" Grid.Row="1" Margin="320,0,0,20" MaxLength="11" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtMobile_PreviewKeyDown"/>
            <TextBox x:Name="txtAddress" Style="{StaticResource tbf}" Grid.Column="0" Grid.ColumnSpan="3" Width="930" Grid.Row="1" Margin="0,100,83.5,0" PreviewKeyDown="txtAddress_PreviewKeyDown"/>
            <TextBox x:Name="txtDetail" Style="{StaticResource tbf}" Grid.Column="0" Grid.ColumnSpan="3" Width="930" Grid.Row="1" Grid.RowSpan="2" Margin="0,55,83.5,0" PreviewKeyDown="txtDetail_PreviewKeyDown"/>
            <TextBox x:Name="txtDay" Style="{StaticResource tbf}" FontSize="25" Grid.Column="0" Grid.ColumnSpan="2" Width="30" Margin="190,0,0,50" MaxLength="2" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtDay_PreviewKeyDown"/>
            <TextBox x:Name="txtMonth" Style="{StaticResource tbf}" FontSize="25" Grid.Column="0" Grid.ColumnSpan="2" Width="30" Margin="55,0,0,50" MaxLength="2" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtMonth_PreviewKeyDown"/>
            <TextBox x:Name="txtYear" Style="{StaticResource tbf}" FontSize="25" Grid.Column="0" Grid.ColumnSpan="2" Width="60" Margin="0,0,110,50" MaxLength="4" FontFamily="pack://application:,,,/Fonts/#B Nazanin" HorizontalContentAlignment="Center" PreviewKeyDown="txtYear_PreviewKeyDown"/>
            <TextBox x:Name="txtFee" Style="{StaticResource tbf}" FontSize="25" Grid.Column="0" Grid.ColumnSpan="2" Width="180" Margin="10,70,0,0" FontFamily="pack://application:,,,/Fonts/#B Nazanin" TextChanged="txtFee_TextChanged" MaxLength="13" HorizontalContentAlignment="Center" PreviewKeyDown="txtFee_PreviewKeyDown"/>
            <TextBox x:Name="txtDiscount" Style="{StaticResource tbf}" Grid.Column="0" Grid.ColumnSpan="2" Width="180" Grid.RowSpan="2" Margin="10,25,0,0" HorizontalContentAlignment="Center" FontSize="25" FontFamily="pack://application:,,,/Fonts/#B Nazanin" MaxLength="13" TextChanged="txtDiscount_TextChanged" PreviewKeyDown="txtDiscount_PreviewKeyDown"/>
            <TextBox x:Name="txtTotal" Style="{StaticResource tbf}" Grid.Column="0" Grid.ColumnSpan="2" Width="180" Grid.Row="1" Margin="0,0,55,20" HorizontalContentAlignment="Center" FontFamily="pack://application:,,,/Fonts/#B Nazanin" FontSize="25" IsReadOnly="True"/>

            <Button Click="dropSeller_Click" x:Name="dropSeller" Width="20" Height="20" VerticalAlignment="Top" Margin="40,50,0,0" Grid.Column="1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Image Source="/Source/Pic/drop2.png"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Border Grid.RowSpan="3" x:Name="sellp" Visibility="Collapsed" Width="500" Height="400" CornerRadius="10" Margin="0,0,120,30" Background="#FFD9D9FF" BorderThickness="2" Grid.ColumnSpan="2" BorderBrush="BlueViolet">
                <Grid>
                    <TextBox x:Name="sellerList" Text=" جستجو..." TextChanged="sellerList_TextChanged" GotFocus="sellerList_GotFocus" LostFocus="sellerList_LostFocus" Style="{StaticResource tbf}" FontSize="25" Width="450" Height="50" Margin="0,0,0,320" Foreground="LightGray" Background="White">
                    </TextBox>
                    <DataGrid x:Name="sGrid" SelectionChanged="sGrid_SelectionChanged" PreviewKeyDown="sGrid_KeyDown" CanUserResizeRows="False" RowHeaderWidth="0" GridLinesVisibility="None" HorizontalScrollBarVisibility="Disabled" CanUserAddRows="False" ItemsSource="{Binding people}" CanUserResizeColumns="False" CanUserReorderColumns="False" Width="450" Height="320" Margin="0,70,0,0" FontSize="18" FontWeight="Bold" AutoGenerateColumns="False" FlowDirection="RightToLeft" FontFamily="pack://application:,,,/Fonts/#Vazir" Background="#FFD9D9FF">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="کد" Width="150" Binding="{Binding PersonIdByUser}"/>
                            <DataGridTextColumn Header="نام" Width="300" Binding="{Binding PersonName}"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Background" Value="LightBlue"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridRow">
                                            <Border CornerRadius="3" Background="{TemplateBinding Background}">
                                                <DataGridCellsPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </Border>

            <Button x:Name="save" Click="Save_Click" Style="{StaticResource ubtn}" Content="  ذخیره اطلاعات" Tag="/Source/pic/save.png" Grid.Column="2" Grid.Row="2" Margin="170,80,0,0">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource tip}" Content="ثبت اطلاعات" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
                </Button.ToolTip>
            </Button>
            <Button x:Name="exit" Click="exit_Click" Style="{StaticResource ubtn}" Content="         خروج" Tag="/Source/pic/cancel.png" Grid.Column="2" Grid.Row="2" Margin="170,80,0,0" Visibility="Collapsed">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource tip}" Content="ثبت اطلاعات" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
                </Button.ToolTip>
            </Button>
            <Button x:Name="cancel" Click="Cancel_Click" Style="{StaticResource ubtn}" Content="      انصراف" Tag="/Source/pic/cancel.png" Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2" Margin="200,80,0,0">
                <Button.ToolTip>
                    <ToolTip Style="{StaticResource tip}" Content="انصراف" Placement="Bottom" VerticalOffset="5" HorizontalOffset="50"/>
                </Button.ToolTip>
            </Button>

        </Grid>
    </Border>
</UserControl>
